{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Lingkyn/xr-foundry/blob/main/docs/contributing/tasks/task-registry.schema.json",
  "title": "XR Foundry live task registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "revision", "generated_at", "coverage", "authority", "tasks"],
  "properties": {
    "schema": { "const": "xr-foundry.task_registry.v1" },
    "revision": { "type": "integer", "minimum": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "unregistered_issue_contract"],
      "properties": {
        "mode": { "const": "explicit_registration" },
        "unregistered_issue_contract": { "const": "issue_declared_claim_key" }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registered_record", "umbrella_issue", "checkpoint_issue", "project"],
      "properties": {
        "registered_record": { "const": "fine_grained_execution_authority" },
        "umbrella_issue": { "const": "coordination_projection" },
        "checkpoint_issue": { "const": "checkpoint_coordination_projection" },
        "project": { "const": "discovery_summary" }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_id", "contract", "umbrella_issue", "state"],
        "properties": {
          "task_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" },
          "contract": {
            "type": "string",
            "pattern": "^docs/contributing/tasks/[A-Za-z0-9._-]+\\.task\\.json$"
          },
          "umbrella_issue": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://github\\.com/[A-Za-z0-9-]+/[A-Za-z0-9._-]+/issues/[1-9][0-9]*$"
          },
          "state": {
            "enum": [
              "proposal",
              "source_gate",
              "ready",
              "active",
              "waiting",
              "integration",
              "closed",
              "cancelled"
            ]
          }
        }
      }
    }
  }
}
