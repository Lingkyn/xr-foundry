{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Lingkyn/xr-foundry/blob/main/docs/device-lab/capability-test-plan.schema.json",
  "title": "XR Foundry capability test plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "test_plan_id",
    "capability",
    "allowed_targets",
    "allowed_package_compositions",
    "execution_requirements",
    "required_checks",
    "optional_checks",
    "non_claims"
  ],
  "properties": {
    "schema": { "const": "xr-foundry.capability_test_plan.v1" },
    "test_plan_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "capability": { "type": "string", "minLength": 1 },
    "allowed_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "device_profile_id",
          "composition_ids",
          "required_input_routes",
          "required_input_source_ids"
        ],
        "properties": {
          "device_profile_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "composition_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
            "minItems": 1,
            "uniqueItems": true
          },
          "required_input_routes": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
            "minItems": 1,
            "uniqueItems": true
          },
          "required_input_source_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
            "minItems": 1,
            "uniqueItems": true
          }
        }
      }
    },
    "allowed_package_compositions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "required_claim_id", "domain", "presentation", "renderer_adapter", "xr_adapter"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "required_claim_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "domain": { "type": "string", "minLength": 1 },
          "presentation": { "type": "string", "minLength": 1 },
          "renderer_adapter": { "type": "string", "minLength": 1 },
          "xr_adapter": { "type": "string", "minLength": 1 }
        }
      }
    },
    "execution_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum_duration_seconds", "allowed_postures", "required_resolved_packages"],
      "properties": {
        "minimum_duration_seconds": { "type": "integer", "minimum": 1 },
        "allowed_postures": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "minItems": 1,
          "uniqueItems": true
        },
        "required_resolved_packages": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z0-9]+(?:[._-][A-Za-z0-9]+)+$" },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "required_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "purpose", "expected"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "purpose": { "type": "string", "minLength": 1 },
          "expected": { "type": "string", "minLength": 1 }
        }
      }
    },
    "optional_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "claim_id", "required_input_route", "purpose", "expected"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "claim_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "required_input_route": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "purpose": { "type": "string", "minLength": 1 },
          "expected": { "type": "string", "minLength": 1 }
        }
      }
    },
    "non_claims": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    }
  }
}
