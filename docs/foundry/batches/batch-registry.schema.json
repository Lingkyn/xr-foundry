{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Lingkyn/xr-foundry/blob/main/docs/foundry/batches/batch-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "batches"],
  "properties": {
    "schema": { "const": "xr-foundry.batch_registry.v1" },
    "batches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "state", "release_tag"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "path": { "type": "string", "pattern": "^docs/foundry/batches/[a-z0-9.-]+\\.json$" },
          "state": { "enum": ["building", "approved_for_release", "released"] },
          "release_tag": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              { "type": "null" }
            ]
          }
        },
        "allOf": [
          {
            "if": { "properties": { "state": { "const": "released" } }, "required": ["state"] },
            "then": { "properties": { "release_tag": { "type": "string", "minLength": 1 } } }
          }
        ]
      }
    }
  }
}
