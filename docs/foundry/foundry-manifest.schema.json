{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Lingkyn/xr-foundry/blob/main/docs/foundry/foundry-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "lifecycle", "validation_levels", "surfaces", "authority"],
  "properties": {
    "schema": { "const": "xr-foundry.production_line.v1" },
    "version": { "const": "1.2.0" },
    "lifecycle": {
      "const": [
        "proposal", "system_scope_gate", "source_gate", "admitted_blueprint", "scaffold", "build",
        "fast_validation", "exact_consumer_validation", "independent_review",
        "maturity_promotion", "release", "observation"
      ]
    },
    "validation_levels": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "claim_ceiling", "required_for"],
        "properties": {
          "id": { "enum": ["fast_structure", "repository_contract", "exact_consumer", "named_device"] },
          "claim_ceiling": { "type": "string", "minLength": 1 },
          "required_for": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
        }
      }
    },
    "surfaces": {
      "type": "object",
      "additionalProperties": false,
      "required": ["first_batch", "batch_registry", "next_queue", "system_admission_schema", "blueprint_schema", "source_manifest", "release_policy"],
      "properties": {
        "first_batch": { "const": "docs/foundry/batches/unity-first-batch.v1.json" },
        "batch_registry": { "const": "docs/foundry/batches/batch-registry.v1.json" },
        "next_queue": { "const": "docs/foundry/queue/next-batch.json" },
        "system_admission_schema": { "const": "docs/foundry/system-admission.schema.json" },
        "blueprint_schema": { "const": "docs/foundry/unity-package-blueprint.schema.json" },
        "source_manifest": { "const": "docs/foundry/source-manifest.json" },
        "release_policy": { "const": "docs/foundry/release-policy.md" }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scaffold_grants_catalog_admission", "automation_grants_maturity", "agent_grants_release", "automated_evidence_grants_device_claim"],
      "properties": {
        "scaffold_grants_catalog_admission": { "const": false },
        "automation_grants_maturity": { "const": false },
        "agent_grants_release": { "const": false },
        "automated_evidence_grants_device_claim": { "const": false }
      }
    }
  }
}
