{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Lingkyn/xr-foundry/blob/main/docs/validation/compatibility-evidence.schema.json",
  "title": "XR Foundry compatibility evidence receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema",
    "kind",
    "profile_id",
    "commit_sha",
    "target",
    "package_versions",
    "resolved_dependencies",
    "manifest",
    "lock",
    "checks"
  ],
  "properties": {
    "$schema": { "const": "docs/validation/compatibility-evidence.schema.json" },
    "schema": { "const": "xr-foundry.compatibility_evidence.v1" },
    "kind": {
      "enum": ["editor_automated", "android_build", "device_runtime"]
    },
    "profile_id": { "type": "string", "minLength": 1 },
    "commit_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "target": { "$ref": "#/$defs/target" },
    "package_versions": { "$ref": "#/$defs/packageVersions" },
    "resolved_dependencies": { "$ref": "#/$defs/dependencyVersions" },
    "manifest": { "$ref": "#/$defs/boundArtifact" },
    "lock": { "$ref": "#/$defs/boundArtifact" },
    "device_lab_receipt": { "$ref": "#/$defs/deviceLabReceiptArtifact" },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/check" }
    }
  },
  "$defs": {
    "axis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "unityAxis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": {
          "type": "string",
          "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)[abfp](?:0|[1-9][0-9]*)$"
        }
      }
    },
    "semanticAxis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": {
          "type": "string",
          "pattern": "^(?:not_applicable|(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?)$"
        }
      }
    },
    "runtimeAxis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": {
          "type": "string",
          "pattern": "^(?:not_applicable|(?:0|[1-9][0-9]*)(?:\\.[0-9A-Za-z]+)+(?:[-+._][0-9A-Za-z]+)*)$"
        }
      }
    },
    "dependencyVersions": {
      "type": "object",
      "propertyNames": { "pattern": "^com\\.[a-z0-9.-]+$" },
      "additionalProperties": {
        "type": "string",
        "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
      }
    },
    "packageVersions": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "pattern": "^com\\.lingkyn\\.[a-z0-9.-]+$" },
      "additionalProperties": {
        "type": "string",
        "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine",
        "editor",
        "renderer",
        "requested_dependencies",
        "resolved_dependencies",
        "build_target",
        "graphics_api",
        "scripting_backend",
        "architecture",
        "xr_provider",
        "runtime",
        "input_routes",
        "device"
      ],
      "properties": {
        "engine": { "$ref": "#/$defs/unityAxis" },
        "editor": { "$ref": "#/$defs/unityAxis" },
        "renderer": { "$ref": "#/$defs/semanticAxis" },
        "requested_dependencies": { "$ref": "#/$defs/dependencyVersions" },
        "resolved_dependencies": { "$ref": "#/$defs/dependencyVersions" },
        "build_target": { "type": "string", "minLength": 1 },
        "graphics_api": { "type": "string", "minLength": 1 },
        "scripting_backend": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "xr_provider": { "$ref": "#/$defs/semanticAxis" },
        "runtime": { "$ref": "#/$defs/runtimeAxis" },
        "input_routes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "device": { "$ref": "#/$defs/runtimeAxis" }
      }
    },
    "boundArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^docs/validation/evidence/[A-Za-z0-9._/-]+$"
        },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "deviceLabReceiptArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^docs/device-lab/receipts/[A-Za-z0-9._-]+\\.json$"
        },
        "sha256": { "type": "string", "pattern": "^(?!0{64}$)[0-9a-f]{64}$" }
      }
    },
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref", "sha256"],
      "properties": {
        "kind": {
          "enum": [
            "compile_result",
            "nunit_result",
            "build_artifact",
            "device_lab_receipt"
          ]
        },
        "ref": {
          "type": "string",
          "pattern": "^(?:docs/validation/evidence/[A-Za-z0-9._/-]+|docs/device-lab/receipts/[A-Za-z0-9._-]+\\.json)$"
        },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "evidence_refs"],
      "properties": {
        "id": {
          "enum": [
            "editor_compile",
            "editmode_tests",
            "playmode_tests",
            "android_build",
            "device_runtime"
          ]
        },
        "status": { "enum": ["pass", "fail", "not_run"] },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "pass" } }, "required": ["status"] },
          "then": { "properties": { "evidence_refs": { "minItems": 1 } } }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "device_runtime" } }, "required": ["kind"] },
      "then": { "required": ["device_lab_receipt"] },
      "else": { "not": { "required": ["device_lab_receipt"] } }
    }
  ]
}
