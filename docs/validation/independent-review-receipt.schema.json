{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Lingkyn/xr-foundry/blob/main/docs/validation/independent-review-receipt.schema.json",
  "title": "XR Foundry independent review receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "record_status",
    "repository",
    "task_id",
    "checkpoint_id",
    "task_revision",
    "reviewed_commit",
    "executor",
    "independent_review",
    "maintainer_decision",
    "scope",
    "checks",
    "findings",
    "conclusion",
    "reviewed_at",
    "limitations",
    "authority"
  ],
  "properties": {
    "schema": { "const": "xr-foundry.independent_review_receipt.v1" },
    "record_status": { "enum": ["example", "accepted"] },
    "repository": { "const": "https://github.com/Lingkyn/xr-foundry" },
    "task_id": { "$ref": "#/$defs/nonEmptyString" },
    "checkpoint_id": { "$ref": "#/$defs/nonEmptyString" },
    "task_revision": { "type": "integer", "minimum": 1 },
    "reviewed_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "executor": { "$ref": "#/$defs/actor" },
    "independent_review": {
      "allOf": [
        { "$ref": "#/$defs/actor" },
        {
          "type": "object",
          "required": ["fresh_context", "reviewed_own_output"],
          "properties": {
            "fresh_context": { "const": true },
            "reviewed_own_output": { "const": false }
          }
        }
      ]
    },
    "maintainer_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["github_identity", "decision", "decision_url"],
      "properties": {
        "github_identity": { "$ref": "#/$defs/nonEmptyString" },
        "decision": { "enum": ["approved", "changes_requested"] },
        "decision_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://github\\.com/Lingkyn/xr-foundry/"
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_paths", "acceptance_ids", "excluded_claims"],
      "properties": {
        "allowed_paths": { "$ref": "#/$defs/nonEmptyStringArray" },
        "acceptance_ids": { "$ref": "#/$defs/nonEmptyStringArray" },
        "excluded_claims": { "$ref": "#/$defs/nonEmptyStringArray" }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "command", "status", "evidence"],
        "properties": {
          "id": { "$ref": "#/$defs/nonEmptyString" },
          "command": { "$ref": "#/$defs/nonEmptyString" },
          "status": { "enum": ["pass", "fail", "blocked", "not_run"] },
          "evidence": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "severity", "status", "summary", "evidence"],
        "properties": {
          "id": { "$ref": "#/$defs/nonEmptyString" },
          "severity": { "enum": ["low", "medium", "high", "critical"] },
          "status": { "enum": ["open", "resolved", "accepted_limit"] },
          "summary": { "$ref": "#/$defs/nonEmptyString" },
          "evidence": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    },
    "conclusion": { "enum": ["pass", "changes_required"] },
    "reviewed_at": { "type": "string", "format": "date-time" },
    "limitations": { "type": "array", "items": { "$ref": "#/$defs/nonEmptyString" } },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_grants_write_permission",
        "review_grants_merge_permission",
        "agent_review_replaces_maintainer_decision",
        "device_claim_inferred"
      ],
      "properties": {
        "review_grants_write_permission": { "const": false },
        "review_grants_merge_permission": { "const": false },
        "agent_review_replaces_maintainer_decision": { "const": false },
        "device_claim_inferred": { "const": false }
      }
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["github_identity", "assisted_by"],
      "properties": {
        "github_identity": { "$ref": "#/$defs/nonEmptyString" },
        "assisted_by": { "$ref": "#/$defs/nonEmptyStringArray" },
        "fresh_context": { "type": "boolean" },
        "reviewed_own_output": { "type": "boolean" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "record_status": { "const": "accepted" } },
        "required": ["record_status"]
      },
      "then": {
        "properties": {
          "maintainer_decision": {
            "properties": { "decision": { "const": "approved" } }
          },
          "checks": {
            "items": { "properties": { "status": { "const": "pass" } } }
          },
          "findings": {
            "items": { "properties": { "status": { "enum": ["resolved", "accepted_limit"] } } }
          },
          "conclusion": { "const": "pass" }
        }
      }
    }
  ]
}
