{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Lingkyn/xr-foundry/blob/main/docs/validation/inventory-xr-device-receipt.schema.json",
  "title": "XR Foundry Inventory XR device receipt",
  "type": "object",
  "required": [
    "schema",
    "receipt_id",
    "validation_profile",
    "supported_xr_package_ids",
    "package",
    "artifact",
    "software",
    "device",
    "execution",
    "checks",
    "claim_boundary",
    "overall_result",
    "failures_and_follow_up"
  ],
  "properties": {
    "schema": {
      "const": "xr-foundry.inventory_xr_device_receipt.v2"
    },
    "receipt_id": {
      "$ref": "#/$defs/nonempty_string"
    },
    "validation_profile": {
      "const": "pico_tracked_controller_v1"
    },
    "supported_xr_package_ids": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {
        "enum": [
          "com.lingkyn.inventory.xr.ugui",
          "com.lingkyn.inventory.xr.uitoolkit"
        ]
      },
      "allOf": [
        {
          "contains": {
            "const": "com.lingkyn.inventory.xr.ugui"
          }
        },
        {
          "contains": {
            "const": "com.lingkyn.inventory.xr.uitoolkit"
          }
        }
      ]
    },
    "package": {
      "type": "object",
      "required": ["id", "renderer", "version", "revision"],
      "properties": {
        "id": {
          "enum": [
            "com.lingkyn.inventory.xr.ugui",
            "com.lingkyn.inventory.xr.uitoolkit"
          ]
        },
        "renderer": {
          "enum": ["ugui", "uitoolkit"]
        },
        "version": {
          "$ref": "#/$defs/nonempty_string"
        },
        "revision": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{40}$"
        }
      },
      "oneOf": [
        {
          "properties": {
            "id": {
              "const": "com.lingkyn.inventory.xr.ugui"
            },
            "renderer": {
              "const": "ugui"
            }
          }
        },
        {
          "properties": {
            "id": {
              "const": "com.lingkyn.inventory.xr.uitoolkit"
            },
            "renderer": {
              "const": "uitoolkit"
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": ["apk_sha256", "artifact_ref", "application_id"],
      "properties": {
        "apk_sha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "artifact_ref": {
          "$ref": "#/$defs/nonempty_string"
        },
        "application_id": {
          "$ref": "#/$defs/nonempty_string"
        }
      },
      "additionalProperties": false
    },
    "software": {
      "type": "object",
      "required": [
        "unity_version",
        "xri_version",
        "xr_management_version",
        "openxr_version",
        "pico_integration_version",
        "runtime_provider",
        "android_target_api",
        "graphics_api"
      ],
      "additionalProperties": {
        "$ref": "#/$defs/nonempty_string"
      }
    },
    "device": {
      "type": "object",
      "required": [
        "manufacturer",
        "model",
        "os_version",
        "firmware_version",
        "controller_input_mode"
      ],
      "properties": {
        "manufacturer": {
          "const": "PICO"
        },
        "model": {
          "$ref": "#/$defs/nonempty_string"
        },
        "os_version": {
          "$ref": "#/$defs/nonempty_string"
        },
        "firmware_version": {
          "$ref": "#/$defs/nonempty_string"
        },
        "controller_input_mode": {
          "const": "tracked_controllers"
        }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "required": [
        "tested_at_utc",
        "tester",
        "sample_scene",
        "posture",
        "duration_seconds",
        "install_result",
        "open_result"
      ],
      "properties": {
        "tested_at_utc": {
          "$ref": "#/$defs/nonempty_string"
        },
        "tester": {
          "$ref": "#/$defs/nonempty_string"
        },
        "sample_scene": {
          "$ref": "#/$defs/nonempty_string"
        },
        "posture": {
          "$ref": "#/$defs/nonempty_string"
        },
        "duration_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "install_result": {
          "$ref": "#/$defs/check_status"
        },
        "open_result": {
          "$ref": "#/$defs/check_status"
        }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "claim_boundary": {
      "type": "object",
      "required": [
        "device_gate_passed",
        "headset_usability_claim_allowed",
        "controller_ray_claim_allowed",
        "direct_poke_device_claim_allowed"
      ],
      "properties": {
        "device_gate_passed": {
          "type": "boolean"
        },
        "headset_usability_claim_allowed": {
          "type": "boolean"
        },
        "controller_ray_claim_allowed": {
          "type": "boolean"
        },
        "direct_poke_device_claim_allowed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "overall_result": {
      "enum": ["pass", "partial", "fail", "not_run"]
    },
    "failures_and_follow_up": {
      "type": "array"
    }
  },
  "$defs": {
    "nonempty_string": {
      "type": "string",
      "minLength": 1
    },
    "check_status": {
      "enum": ["pass", "partial", "fail", "not_tested"]
    },
    "check": {
      "type": "object",
      "required": ["id", "status", "observation", "evidence_refs"],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonempty_string"
        },
        "status": {
          "$ref": "#/$defs/check_status"
        },
        "observation": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonempty_string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
